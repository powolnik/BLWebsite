# ============================================
# RENDER ENVIRONMENT VARIABLES
# Ustaw te zmienne w: Render Dashboard → Environment
# NIE COMMITUJ prawdziwych wartości!
# ============================================

DJANGO_SETTINGS_MODULE=config.settings.prod
PYTHON_VERSION=3.12.0

# Wygeneruj: python3 -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=WYGENERUJ-BEZPIECZNY-KLUCZ

# Render ustawia to automatycznie po połączeniu bazy PostgreSQL
# DATABASE_URL=postgres://user:pass@host:5432/dbname

ALLOWED_HOSTS=.onrender.com

# Opcjonalne (domyślnie niepotrzebne — frontend na tej samej domenie)
# CORS_ALLOWED_ORIGINS=https://inna-domena.com
